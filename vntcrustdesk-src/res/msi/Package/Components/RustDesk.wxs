			</Component>
			<Component Guid="79a395eb-7570-4d6e-a41e-6ade8a691df4" Subdirectory="usbmmidd_v2">
				<File Source="D:/Myproject/vnt2.0/vntcrustdesk-src/vntcrustdesk/usbmmidd_v2/idd_instructions.txt" KeyPath="yes" Checksum="yes" />

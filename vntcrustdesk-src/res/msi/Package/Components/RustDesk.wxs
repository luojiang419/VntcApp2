			</Component>
			<Component Guid="e23c0a7b-6172-42d0-947a-9c080c577308" Subdirectory="data\flutter_assets">
				<File Source="D:/Myproject/vnt2.0/vntcrustdesk-src/vntcrustdesk/data/flutter_assets/FontManifest.json" KeyPath="yes" Checksum="yes" />
			</Component>
			<Component Guid="81c09b1c-2d34-4dd3-ae80-c02c17c3177e" Subdirectory="data\flutter_assets">
				<File Source="D:/Myproject/vnt2.0/vntcrustdesk-src/vntcrustdesk/data/flutter_assets/NativeAssetsManifest.json" KeyPath="yes" Checksum="yes" />
			</Component>
			<Component Guid="51656b90-20d1-4248-b191-69ef6a1a4f82" Subdirectory="data\flutter_assets">
				<File Source="D:/Myproject/vnt2.0/vntcrustdesk-src/vntcrustdesk/data/flutter_assets/NOTICES.Z" KeyPath="yes" Checksum="yes" />
			</Component>
			<Component Guid="1cc0871c-463b-4be2-b184-86ec752b25fe" Subdirectory="data\flutter_assets\assets">

			<Component Guid="bef4d27e-bd3c-469e-afe1-ff82b03cdc64" Subdirectory="data\flutter_assets\assets">
				<File Source="D:/Myproject/vnt2.0/vntcrustdesk-src/vntcrustdesk/data/flutter_assets/assets/auth-okta.svg" KeyPath="yes" Checksum="yes" />
